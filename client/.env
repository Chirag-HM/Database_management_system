# ─────────────────────────────────────────────────────────
# Frontend Environment Variables
# ─────────────────────────────────────────────────────────
# Vite exposes any variable prefixed with VITE_ to your
# client-side code via import.meta.env.VITE_VARIABLE_NAME
#
# IMPORTANT: After changing this file, RESTART the Vite
# dev server (npm run dev) for changes to take effect.
# ─────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:5000
